# --- Git ---
.git/
.gitignore

# --- Python ---
__pycache__/
*.py[cod]
*.so
.Python

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Environment variables / secrets ---
.env
.env.*
!.env.example

# --- Runtime data generated by the app (don't bake into the image) ---
downloads/
vector_database/
sessions.json

# --- IDE / editor ---
.vscode/
.idea/
*.swp

# --- OS junk ---
.DS_Store
Thumbs.db

# --- Logs ---
*.log

# --- Docker-related files not needed inside the build context ---
docker-compose.yml
docker-compose.override.yml
dockerfile.backend
dockerfile.frontend

# --- Docs / misc (not needed at runtime) ---
README.md